{
  "name": "personal-assistant",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "cd packages/backend && pnpm dev",
    "dev:frontend": "cd packages/frontend && pnpm dev",
    "build": "pnpm build:types && pnpm build:drizzle && pnpm build:backend && pnpm build:frontend",
    "build:types": "cd packages/types && pnpm build",
    "build:drizzle": "cd packages/drizzle && pnpm build",
    "build:backend": "cd packages/backend && pnpm build",
    "build:frontend": "cd packages/frontend && pnpm build",
    "lint": "pnpm lint:types && pnpm lint:drizzle && pnpm lint:backend && pnpm lint:frontend",
    "lint:types": "cd packages/types && pnpm lint",
    "lint:drizzle": "cd packages/drizzle && pnpm lint",
    "lint:backend": "cd packages/backend && pnpm lint",
    "lint:frontend": "cd packages/frontend && pnpm lint",
    "typecheck": "pnpm typecheck:types && pnpm typecheck:drizzle && pnpm typecheck:backend && pnpm typecheck:frontend",
    "typecheck:types": "cd packages/types && pnpm typecheck",
    "typecheck:drizzle": "cd packages/drizzle && pnpm typecheck",
    "typecheck:backend": "cd packages/backend && pnpm typecheck",
    "typecheck:frontend": "cd packages/frontend && pnpm typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.6"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  }
}
