{
  "name": "@personal-assistant/frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev -p 3000",
    "dev:turbo": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint . --ext ts,tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@personal-assistant/types": "workspace:*",
    "lucide-react": "^0.479.0",
    "next": "16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.23.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
